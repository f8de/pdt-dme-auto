{
  "_notes": "UI control registry for DMEworks automation. Update from probe output (python tools/map_customer_form.py → logs/customer_form_map.txt).",

  "app": {
    "title": "DMEWorks",
    "auto_id": "FormMain",
    "popups": {
      "compliance": { "title": "Compliance Popup", "auto_id": "FormCompliancePopup", "close_button": "Close" },
      "save_dialog_no": { "title": "No", "control_type": "Button" }
    }
  },

  "doctor": {
    "menu_path": "Maintain->Doctor",
    "form_keyword": "Doctor",
    "toolbar": "tlbMain",
    "page_control": "PageControl",
    "search_tab": {
      "tab_title": "Search",
      "filter_field": "txtFilter",
      "grid": { "auto_id": "Grid", "control_type": "Table" },
      "grid_rows": { "control_type": "Custom", "title_pattern": "Row {n}" },
      "grid_columns": ["ID", "Last Name", "First Name", "Address", "City", "State", "UPIN"],
      "_note": "Rows pre-loaded; type last name in txtFilter then double-click Row N to open in Work Area"
    },
    "work_area_tab": "Work Area",
    "name_pane": {
      "auto_id": "CName",
      "parent": "Panel1",
      "fields": {
        "last":     { "auto_id": "txtLastName" },
        "first":    { "auto_id": "txtFirstName" },
        "mi":       { "auto_id": "txtMiddleName" },
        "suffix":   { "auto_id": "txtSuffix" },
        "courtesy": { "auto_id": "cmbCourtesy", "type": "combo", "inner_auto_id": "1001" }
      }
    },
    "tab_control": "TabControl1",
    "tabs": {
      "Address": {
        "pane_id": "tpAddress",
        "fields": {
          "address1": { "auto_id": "txtAddress1" },
          "address2": { "auto_id": "txtAddress2" },
          "city":     { "auto_id": "txtCity" },
          "state":    { "auto_id": "txtState" },
          "zip":      { "auto_id": "txtZip" },
          "phone":    { "auto_id": "txtPhone", "format": "phone" },
          "fax":      { "auto_id": "txtFax" }
        }
      },
      "Numbers": {
        "pane_id": "tpNumbers",
        "fields": {
          "npi":             { "auto_id": "txtNPI" },
          "upin":            { "auto_id": "txtUPINNumber" },
          "other_id":        { "auto_id": "txtOtherID" },
          "medicaid_number": { "auto_id": "txtMedicaidNumber" },
          "dea_number":      { "auto_id": "txtDEANumber" },
          "license_number":  { "auto_id": "txtLicenseNumber" },
          "fed_tax_id":      { "auto_id": "txtFEDTaxID" },
          "pecos_enrolled":  { "auto_id": "chbPecosEnrolled", "type": "checkbox" }
        }
      },
      "Marketing Information": {
        "pane_id": "tpMarketing",
        "fields": {
          "doctor_type": { "auto_id": "cmbDoctorType", "type": "combo_search", "inner_auto_id": "cmbInternal" },
          "title":       { "auto_id": "txtTitle" },
          "contact":     { "auto_id": "txtContact" }
        }
      }
    }
  },

  "insurance_company": {
    "menu_path": "Maintain->Insurance Company",
    "form_keyword": "Insurance Company",
    "toolbar": "tlbMain",
    "fields": {
      "name": { "auto_id": "txtName" }
    }
  },

  "customer": {
    "menu_path": "Maintain->Customer",
    "form_keyword": "Customer",
    "form_auto_id": "FormCustomer",
    "toolbar": "tlbMain",
    "name_pane": {
      "auto_id": "CName",
      "parent": "Panel1",
      "fields": {
        "last":     { "auto_id": "txtLastName" },
        "first":    { "auto_id": "txtFirstName" },
        "mi":       { "auto_id": "txtMiddleName" },
        "suffix":   { "auto_id": "txtSuffix" },
        "courtesy": { "auto_id": "cmbCourtesy", "type": "combo", "inner_auto_id": "1001" }
      }
    },
    "tab_control": "TabControl1",
    "tabs": {
      "General": {
        "pane_id": "tpGeneral",
        "fields": {
          "dob":      { "auto_id": "dtbDateofBirth", "type": "date" },
          "address1": { "auto_id": "txtAddress1", "parent_pane": "CAddress" },
          "address2": { "auto_id": "txtAddress2", "parent_pane": "CAddress" },
          "city":     { "auto_id": "txtCity",     "parent_pane": "CAddress" },
          "state":    { "auto_id": "txtState",    "parent_pane": "CAddress" },
          "zip":      { "auto_id": "txtZip",      "parent_pane": "CAddress" },
          "phone":    { "auto_id": "txtPhone", "format": "phone" },
          "phone2":   { "auto_id": "txtPhone2" },
          "email":    { "auto_id": "txtEmail" }
        }
      },
      "Notes": {
        "pane_id": "tpNotes",
        "control": "ControlCustomerNotes1",
        "add_button": "btnAdd",
        "_note": "Notes grid — click btnAdd then type into 'Notes Row 0' cell"
      },
      "Contacts": {
        "pane_id": "tpContacts",
        "fields": {
          "doctor1":  { "auto_id": "cmbDoctor1",  "type": "combo_search", "inner_auto_id": "cmbInternal" },
          "doctor2":  { "auto_id": "cmbDoctor2",  "type": "combo_search", "inner_auto_id": "cmbInternal" },
          "facility": { "auto_id": "cmbFacility", "type": "combo_search", "inner_auto_id": "cmbInternal" },
          "emergency_contact": { "auto_id": "txtEmergencyContact" }
        }
      },
      "Diagnosis": {
        "pane_id": "tpDiagnosis",
        "tab_control": "TabControl2",
        "icd10_tab": "ICD 10",
        "icd10_pane": "TabPage3",
        "icd10_slots": {
          "auto_id_pattern": "eddICD10_{nn}",
          "inner_auto_id": "txtInternal",
          "count": 12
        }
      },
      "Insurance": {
        "pane_id": "tpInsurance",
        "control_pane": "ControlCustomerInsurance1",
        "add_button_pane": "Panel1",
        "add_button": "btnAdd",
        "policy_dialog": {
          "fields": {
            "insurance_company": { "auto_id": "cmbInsuranceCompany", "type": "combo_search" },
            "insurance_type":    { "auto_id": "cmbInsuranceType",    "type": "combo_search" },
            "policy_number":     { "auto_id": "txtPolicyNumber" },
            "group_number":      { "auto_id": "txtGroupNumber" }
          },
          "buttons": {
            "ok":     { "auto_id": "btnOK" },
            "cancel": { "auto_id": "btnCancel" }
          }
        }
      },
      "Personal": {
        "pane_id": "tpPersonal",
        "fields": {
          "gender":               { "auto_id": "cmbGender",              "type": "combo",       "inner_auto_id": "1001" },
          "height":               { "auto_id": "nmbHeight",              "type": "numeric_pane", "inner_auto_id": "txtInternal" },
          "weight":               { "auto_id": "nmbWeight",              "type": "numeric_pane", "inner_auto_id": "txtInternal" },
          "delivery_directions":  { "auto_id": "txtDeliveryDirections" },
          "ssn":                  { "auto_id": "txtSSNumber" },
          "license":              { "auto_id": "txtLicense" },
          "marital_status":       { "auto_id": "cmbMaritalStatus",       "type": "combo", "inner_auto_id": "1001" },
          "employment_status":    { "auto_id": "cmbEmploymentStatus",    "type": "combo", "inner_auto_id": "1001" },
          "student_status":       { "auto_id": "cmbStudentStatus",       "type": "combo", "inner_auto_id": "1001" },
          "military_branch":      { "auto_id": "cmbMilitaryBranch",      "type": "combo", "inner_auto_id": "1001" },
          "military_status":      { "auto_id": "cmbMilitaryStatus",      "type": "combo", "inner_auto_id": "1001" }
        }
      },
      "Billing": {
        "pane_id": "tpAssignment",
        "fields": {
          "signature_on_file": { "auto_id": "dtbSignatureOnFile", "type": "date" },
          "signature_type":    { "auto_id": "cmbSignatureType",   "type": "combo", "inner_auto_id": "1001" },
          "hippa_note":        { "auto_id": "chbHIPPANote",       "type": "checkbox" },
          "supplier_standards":{ "auto_id": "chbSupplierStandards","type": "checkbox" }
        }
      }
    }
  }
}
